<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= data.name %> | Portfolio</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <section class="main">
        <div class="download">
            <button type="button" class="btn btn-light" onclick="window.print()">
                Download <i class="fa-solid fa-download" style="color: rgb(42, 30, 80);"></i>
            </button>
        </div>

        <div class="cir">
            <h1 style="font-size:3rem; display:flex; align-items:center; justify-content:center; height:100%; margin:0; color:#0dcaf0;">
                <%= data.name.charAt(0).toUpperCase() %>
            </h1>
        </div>

        <div class="q">
            <h1 class="nam"><%= data.name %></h1>
            <p class="w"><%= data.education %> | Age <%= data.age %></p>
        </div>

        <div class="redirect">
            <a href="<%= data.github %>" target="_blank" class="btn btn-outline-light">GitHub</a>
            <a href="<%= data.linkedin %>" target="_blank" class="btn btn-outline-light">LinkedIn</a>
            <a href="mailto:<%= data.email %>" class="btn btn-outline-light">Email</a>
        </div>

        <div class="maain">
            <div class="maintwo">

                <div class="sk">
                    <h2><u>Skills</u></h2>
                    <div style="display:flex; flex-wrap:wrap; gap:8px; margin-top:12px;">
                        <% data.skills.split(',').forEach(function(skill) { %>
                            <span style="padding:6px 14px; border-radius:8px; border:1px solid rgba(255,255,255,0.2); background:rgba(255,255,255,0.05); color:#fff; font-size:0.9rem;">
                                <%= skill.trim() %>
                            </span>
                        <% }); %>
                    </div>
                    <h3 style="margin-top:20px; font-size:1rem; color:#0dcaf0;">Interests</h3>
                    <p style="color:rgba(255,255,255,0.6);"><%= data.interests %></p>
                </div>

                <div class="pro">
                    <h2><u>Projects</u></h2>
                    <% if(data.projects && data.projects.length > 0) { %>
                        <% data.projects.forEach(function(project) { %>
                            <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:16px; margin-top:12px;">
                                <h4 style="color:#0dcaf0;"><%= project.title %></h4>
                                <p style="color:rgba(255,255,255,0.6);"><%= project.desc %></p>
                                <a href="<%= project.link %>" target="_blank" style="color:#0dcaf0;">View Project</a>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <p style="color:rgba(255,255,255,0.4);">No projects added.</p>
                    <% } %>
                </div>

            </div>
            <div class="mainthree">

                <div class="internship-exp">
                    <h2><u>Internship Experience</u></h2>
                    <% if(data.internships && data.internships.length > 0) { %>
                        <% data.internships.forEach(function(intern) { %>
                            <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:16px; margin-top:12px;">
                                <h4 style="color:#0dcaf0;"><%= intern.role %> • <%= intern.company %></h4>
                                <p style="color:#8b5cf6; font-size:0.85rem;"><%= intern.start %> — <%= intern.end %></p>
                                <p style="color:rgba(255,255,255,0.6);"><%= intern.learn %></p>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <p style="color:rgba(255,255,255,0.4);">No internship experience added.</p>
                    <% } %>
                </div>

                <div class="achieve">
                    <h2><u>Achievements & Certifications</u></h2>
                    <% if(data.achievements && data.achievements.length > 0) { %>
                        <% data.achievements.forEach(function(ach) { %>
                            <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:16px; margin-top:12px;">
                                <h4>🏆 <%= ach.title %></h4>
                                <p style="color:rgba(255,255,255,0.6);"><%= ach.issued %> — <%= ach.year %></p>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <p style="color:rgba(255,255,255,0.4);">No achievements added.</p>
                    <% } %>
                </div>

            </div>
        </div>

        <footer class="foot">Created by Ritwik Joshi</footer>
    </section>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>